# Server
PORT=3001
NODE_ENV=development

# JWT (e.g. openssl rand -hex 32)
JWT_SECRET=your-jwt-secret-at-least-32-chars

# Privy (dashboard.privy.io) – for server-side signing (prediction market, perp, vault txs)
PRIVY_APP_ID=
PRIVY_APP_SECRET=
PRIVY_KEY_QUORUM_ID=
AUTHORIZATION_PRIVATE_KEY_PATH=./private.pem

# MongoDB – required for auth/trade (linked wallets)
MONGODB_URI=
MONGODB_DB_NAME=marshmallow

# Chain (Sepolia = 11155111)
CHAIN_ID=11155111
RPC_URL=https://rpc.sepolia.org

# Optional: path to contracts/deployments folder (default: ../contracts/deployments from cwd).
# If set, backend loads addresses from deployments/<CHAIN_ID>.json and uses them when env vars below are unset.
# CONTRACT_DEPLOYMENTS_PATH=

# Prediction market + privacy token (override deployment file if set)
VAULT_ADDRESS=0xE588a6c73933BFD66Af9b4A07d48bcE59c0D2d13
PAYMENT_TOKEN_ADDRESS=0x8DCd1A16dae564BC2aFeDEAde6Cda2f8Eb52C11b
MARKET_ADDRESS=0x64755Fb72d282541b85628Bb0eFf66Bb60a2A26D
POLICY_ENGINE_ADDRESS=0x01752f60cfe8558ca3BeD9D9C44ec3e47bA92f38
PRIVATE_TOKEN_API_URL=https://convergence2026-token-api.cldev.cloud
POOL_PRIVATE_KEY=
EXPOSURE_LEDGER_PATH=./data/exposure.json

# Perpetuals (from deployment or env)
PERPS_ENGINE_ADDRESS=0x8cF24ced7B2F5c567764ea71BF5eb086D722504E
PRICE_ORACLE_ADDRESS=0xed62db571Ea06fBd8CEf925481cF5FF0e0e4c76e
CHAINLINK_PRICE_FEED_ADDRESS=

# Deployer key: same EOA used to deploy contracts (e.g. forge script DeployAll).
# SimpleToken owner – enables POST /api/admin/mint (faucet). Optional.
DEPLOYER_PRIVATE_KEY=

# Perpetuals + privacy (off-chain margin ledger)
PERPS_MARGIN_LEDGER_PATH=./data/perps-margin.json

# CRE: optional secret for POST /api/perps/cre-signal (X-CRE-Secret header)
CRE_WEBHOOK_SECRET=
